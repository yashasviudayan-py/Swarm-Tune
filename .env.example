# ============================================================
# Swarm-Tune Node Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# Unique identifier for this node (auto-generated if not set)
SWARM_NODE_ID=

# Network interface and port this node listens on
SWARM_HOST=0.0.0.0
SWARM_PORT=9000

# Comma-separated list of bootstrap peer multiaddresses
# Example: /ip4/192.168.1.10/tcp/9000/p2p/QmPeer1Id,...
SWARM_BOOTSTRAP_PEERS=

# Path to this node's local data shard
SWARM_DATA_SHARD_PATH=data/shards/shard_0.pt

# Model configuration
SWARM_MODEL_NAME=gpt2
SWARM_MODEL_SHARD_INDEX=0
SWARM_MODEL_SHARD_TOTAL=1

# Training hyperparameters
SWARM_LEARNING_RATE=1e-4
SWARM_BATCH_SIZE=8
SWARM_NUM_ROUNDS=100

# Aggregation settings
SWARM_AGGREGATION_TIMEOUT_SECS=30
SWARM_MIN_PEERS_FOR_ROUND=2

# Logging
SWARM_LOG_LEVEL=INFO
SWARM_LOG_FORMAT=json

# PyTorch device (mps | cuda | cpu)
SWARM_DEVICE=cpu
