# =============================================================
# Swarm-Tune Node Configuration Template
# Copy this file to .env and fill in the values.
# =============================================================

# ------------------------------------------------------------------
# Identity
# ------------------------------------------------------------------
# Unique name for this node. Auto-generated UUID if left empty.
SWARM_NODE_ID=

# Deterministic Ed25519 seed — only set on the bootstrap node.
# Other nodes leave this empty (random key generated at startup).
SWARM_NODE_KEY_SEED=

# ------------------------------------------------------------------
# Network
# ------------------------------------------------------------------
SWARM_HOST=0.0.0.0
SWARM_PORT=9000

# Comma-separated list of bootstrap peer multiaddresses.
# Format: /ip4/<IP>/tcp/<PORT>/p2p/<PEER_ID>
# Get this from the swarm organizer.
# Leave empty if THIS node is the first bootstrap node.
SWARM_BOOTSTRAP_PEERS=

# ------------------------------------------------------------------
# NAT Traversal (Phase 5+ / internet deployment)
# ------------------------------------------------------------------
# Set to true when running over the internet (not local Docker).
SWARM_ENABLE_RELAY=false
SWARM_ENABLE_HOLE_PUNCHING=false

# Multiaddress of the public circuit-relay node (ask the organizer).
# Example: /ip4/1.2.3.4/tcp/4001/p2p/12D3KooWXXX...
SWARM_RELAY_ADDRS=

# ------------------------------------------------------------------
# Model (Phase 5+)
# ------------------------------------------------------------------
# HuggingFace model name. Use "mlp" for local simulation only.
# Example: gpt2, gpt2-medium, meta-llama/Llama-3-8B
SWARM_MODEL_NAME=gpt2

# Which shard of the model this node trains (0-based).
# All nodes train shard 0 unless model parallelism is configured.
SWARM_MODEL_SHARD_INDEX=0
SWARM_MODEL_SHARD_TOTAL=1

# ------------------------------------------------------------------
# Dataset (Phase 5+)
# ------------------------------------------------------------------
# HuggingFace dataset. Leave empty to use local .pt shard files.
SWARM_DATASET_NAME=wikitext
SWARM_DATASET_CONFIG=wikitext-103-raw-v1
SWARM_MAX_SEQ_LEN=512

# Path to local .pt shard (used only when SWARM_DATASET_NAME is empty).
SWARM_DATA_SHARD_PATH=data/shards/shard_0.pt

# Data shard assignment — MUST be unique per node in the swarm.
# Set DATA_SHARD_INDEX to each node's position (0, 1, 2, ...).
# Set DATA_SHARD_TOTAL to the total number of nodes training together.
# This is independent of MODEL_SHARD_INDEX (layer parallelism).
# Example for a 6-node swarm: node 0 gets index=0, node 1 gets index=1, etc.
SWARM_DATA_SHARD_INDEX=0
SWARM_DATA_SHARD_TOTAL=1

# ------------------------------------------------------------------
# Training Hyperparameters
# ------------------------------------------------------------------
SWARM_LEARNING_RATE=0.0001
SWARM_BATCH_SIZE=8
SWARM_NUM_ROUNDS=100

# ------------------------------------------------------------------
# Aggregation & Fault Tolerance
# ------------------------------------------------------------------
# Seconds to wait for peer gradients per round (default: 30).
SWARM_AGGREGATION_TIMEOUT_SECS=30

# Minimum peers needed to commit a round (default: 2).
SWARM_MIN_PEERS_FOR_ROUND=2

# ------------------------------------------------------------------
# Hardware
# ------------------------------------------------------------------
# Compute device: cpu | mps (Apple Silicon) | cuda (NVIDIA)
SWARM_DEVICE=cpu

# ------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------
SWARM_LOG_LEVEL=INFO
# json = structured logs for production; console = human-readable
SWARM_LOG_FORMAT=json
